#: lib/amanogawa_web/controllers/page_html/sources.html.heex:3
#, elixir-autogen, elixir-format
msgid "Amanogawa est construit entièrement sur des communs : données structurées, résumés encyclopédiques et frontières historiques publiés par des projets ouverts. Cette page liste chaque source, son rôle dans l'application et sa licence exacte."
msgstr "Amanogawa is built entirely on commons: structured data, encyclopedic summaries, and historical borders published by open projects. This page lists every source, its role in the application, and its exact license."

#: lib/amanogawa_web/controllers/page_html/sources.html.heex:112
#, elixir-autogen, elixir-format
msgid "Amanogawa est un projet personnel, développé et publié en logiciel libre. Le code source est disponible sous licence AGPL-3.0."
msgstr "Amanogawa is a personal project, developed and released as free software. The source code is available under the AGPL-3.0 license."

#: lib/amanogawa_web/controllers/page_html/legal.html.heex:3
#, elixir-autogen, elixir-format
msgid "Amanogawa est édité par Thibault Santonja, à titre personnel."
msgstr "Amanogawa is published by Thibault Santonja, in a personal capacity."

#: lib/amanogawa_web/controllers/page_html/privacy.html.heex:16
#, elixir-autogen, elixir-format
msgid "Aucun cookie, aucun traceur"
msgstr "No cookies, no trackers"

#: lib/amanogawa_web/controllers/page_html/privacy.html.heex:8
#, elixir-autogen, elixir-format
msgid "Aucune donnée personnelle collectée"
msgstr "No personal data collected"

#: lib/amanogawa_web/controllers/page_html/privacy.html.heex:3
#, elixir-autogen, elixir-format
msgid "Cette politique est volontairement courte : elle tient en quelques paragraphes parce qu'il n'y a, en pratique, rien à déclarer."
msgstr "This policy is deliberately short: it fits in a few paragraphs because there is, in practice, nothing to declare."

#: lib/amanogawa_web/controllers/page_html/sources.html.heex:33
#, elixir-autogen, elixir-format
msgid "Chaque extrait affiché dans l'application est accompagné d'un lien vers son article d'origine et de la mention de la licence, conformément à l'obligation d'attribution de la CC BY-SA."
msgstr "Every extract shown in the application is accompanied by a link to its source article and the license notice, in accordance with the CC BY-SA attribution requirement."

#: lib/amanogawa_web/components/layouts.ex:149
#, elixir-autogen, elixir-format
msgid "Code source sous licence AGPL-3.0"
msgstr "Source code under the AGPL-3.0 license"

#: lib/amanogawa_web/controllers/page_html/privacy.html.heex:31
#, elixir-autogen, elixir-format
msgid "Comme tout service en ligne, le serveur conserve de brefs journaux techniques (adresse IP, horodatage, page demandée) nécessaires à la sécurité et au bon fonctionnement du service. Ces journaux ne servent à aucun profilage et sont conservés pour une durée courte."
msgstr "Like any online service, the server keeps brief technical logs (IP address, timestamp, requested page) necessary for the security and proper operation of the service. These logs are never used for profiling and are kept for a short duration."

