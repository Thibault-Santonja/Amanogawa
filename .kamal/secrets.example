# Kamal secrets (issue #026): copy this file to `.kamal/secrets` on the
# machine that runs `kamal deploy` (never in this repository, see
# .gitignore) and fill in real values there, or source them from your
# password manager's CLI as Kamal's own documentation recommends.
#
# `.kamal/secrets` is read by config/deploy.yml's `env.secret` and
# `accessories.db.env.secret` entries; Kamal injects each value into the
# container as the matching environment variable, which
# config/runtime.exs then reads exactly as in any other environment.

# Pulls the application image from the registry declared in
# config/deploy.yml (`registry.password`). A GitHub Personal Access Token
# with `read:packages` scope when the registry is ghcr.io.
KAMAL_REGISTRY_PASSWORD=

# Signs and encrypts cookies/sessions (config/runtime.exs). Generate one
# with: mix phx.gen.secret
SECRET_KEY_BASE=

# Full connection URL to the PostGIS accessory declared in
# config/deploy.yml, using the dedicated, non-superuser application role
# (docs/ops/deploy.md, "Role PostgreSQL dedie"), for example:
#   ecto://amanogawa:<role password>@amanogawa-db:5432/amanogawa_prod
# Never the `postgres` superuser: the application only ever needs its own
# database. The hostname is the accessory's container name on Kamal's
# private network for this service; confirm it with
# `kamal accessory details db` after the first `kamal accessory boot db`.
DATABASE_URL=

# Password for the PostGIS accessory's `postgres` superuser
# (accessories.db.env.secret in config/deploy.yml). Administration only
# (creating the application role, backups): the application itself
# connects with the dedicated role above, never as `postgres`.
POSTGRES_PASSWORD=

# Erlang distribution cookie (config/deploy.yml env.secret): read by the
# release at boot (RELEASE_COOKIE) instead of the build-time
# `releases/COOKIE` file baked into the image, so the published image
# never carries a usable cookie. Required by
# `kamal app exec -i "bin/amanogawa remote"`. Generate one with:
#   openssl rand -hex 32
RELEASE_COOKIE=
