# Production environment variables, read by config/runtime.exs.
# Development and test need no .env file: config/dev.exs and config/test.exs
# point to the local Docker PostGIS database (see docker-compose.yml).
# Copy this file to .env and fill in real values on the target host.
# Never commit real secrets.
#
# The Kamal 2 deployment (issue #026, config/deploy.yml) does NOT read
# this file: it injects the same variables into the container directly,
# `clear` values from config/deploy.yml itself and `secret` values from
# `.kamal/secrets` (see .kamal/secrets.example). This file documents the
# exact same contract for any other Docker-based deployment (`docker run
# --env-file .env`, a different orchestrator, a bare-metal systemd unit),
# which is the point of keeping the Dockerfile generic (ADR 0008).

# Full database connection URL, for example: ecto://user:pass@host/amanogawa_prod
DATABASE_URL=

# Secret used to sign and encrypt cookies and sessions.
# Generate one with: mix phx.gen.secret
SECRET_KEY_BASE=

# Public hostname of the deployed application, for example: amanogawa.example.org
PHX_HOST=

# Ecto pool size (Amanogawa.Repo). Optional, defaults to 10
# (config/runtime.exs); raise it only if the database can sustain more
# connections than that default across every deployed instance.
POOL_SIZE=

# HTTP port the application listens on inside its container. Optional,
# defaults to 4000 (config/runtime.exs, matches the Dockerfile's EXPOSE).
PORT=

# Comma-separated list of trusted reverse-proxy/load-balancer IPs or CIDR
# ranges (for example: 10.0.0.0/8 or a specific proxy IP). Only requests
# forwarded through one of these are trusted to set X-Forwarded-For /
# Forwarded, which AmanogawaWeb.Endpoint's RemoteIp plug then uses to
# correct conn.remote_ip before AmanogawaWeb.Plugs.RateLimit keys its
# per-IP quota on it. Leave empty (the default) when the app is not
# deployed behind a reverse proxy: setting this without one would let any
# direct client spoof its own IP and dodge rate limiting.
TRUSTED_PROXIES=

# Alerting (issue #028, option A): sober, self-hosted, no third-party
# tracking/APM service. Leaving ALERT_RECIPIENT_EMAIL empty disables
# alerting entirely; every other variable below has a sensible default
# (config/runtime.exs).
ALERT_RECIPIENT_EMAIL=
ALERT_FROM_EMAIL=
ALERT_ERROR_THRESHOLD=
ALERT_WINDOW_MINUTES=
ALERT_SILENCE_MINUTES=

# Local SMTP relay used to send alerts (issue #028): the same relay
# already in place for the other projects on this VPS, never a
# third-party transactional email provider.
SMTP_RELAY_HOST=
SMTP_RELAY_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SSL=
