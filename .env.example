# Production environment variables, read by config/runtime.exs.
# Development and test need no .env file: config/dev.exs and config/test.exs
# point to the local Docker PostGIS database (see docker-compose.yml).
# Copy this file to .env and fill in real values on the target host.
# Never commit real secrets.

# Full database connection URL, for example: ecto://user:pass@host/amanogawa_prod
DATABASE_URL=

# Secret used to sign and encrypt cookies and sessions.
# Generate one with: mix phx.gen.secret
SECRET_KEY_BASE=

# Public hostname of the deployed application, for example: amanogawa.example.org
PHX_HOST=
