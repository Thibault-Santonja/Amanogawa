# Production environment variables, read by config/runtime.exs.
# Development and test need no .env file: config/dev.exs and config/test.exs
# point to the local Docker PostGIS database (see docker-compose.yml).
# Copy this file to .env and fill in real values on the target host.
# Never commit real secrets.

# Full database connection URL, for example: ecto://user:pass@host/amanogawa_prod
DATABASE_URL=

# Secret used to sign and encrypt cookies and sessions.
# Generate one with: mix phx.gen.secret
SECRET_KEY_BASE=

# Public hostname of the deployed application, for example: amanogawa.example.org
PHX_HOST=

# Comma-separated list of trusted reverse-proxy/load-balancer IPs or CIDR
# ranges (for example: 10.0.0.0/8 or a specific proxy IP). Only requests
# forwarded through one of these are trusted to set X-Forwarded-For /
# Forwarded, which AmanogawaWeb.Endpoint's RemoteIp plug then uses to
# correct conn.remote_ip before AmanogawaWeb.Plugs.RateLimit keys its
# per-IP quota on it. Leave empty (the default) when the app is not
# deployed behind a reverse proxy: setting this without one would let any
# direct client spoof its own IP and dodge rate limiting.
TRUSTED_PROXIES=
