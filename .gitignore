# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where 3rd-party dependencies like ExDoc output generated docs.
/doc/

# Ignore .fetch files in case you like to edit your project deps locally.
/.fetch

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Temporary files, for example, from tests.
/tmp/

# Wallaby's failure screenshots (test/e2e, mix test.e2e).
/screenshots/

# Ignore package tarball (built via "mix hex.build").
amanogawa-*.tar

# Ignore assets that are produced by build tools.
/priv/static/assets/

# Ignore digested assets cache.
/priv/static/cache_manifest.json

# In case you use Node.js/npm, you want to ignore these.
npm-debug.log
/assets/node_modules/


# Environment files (secrets stay out of the repo).
.env

# Kamal secrets (issue #026): the real files live only on the machine that
# runs `kamal deploy`, never in the repository. The glob also covers
# per-destination files (`secrets.production`, `secrets.staging`, ...);
# `.kamal/secrets.example` (no real values) is the only committed exception.
/.kamal/secrets*
!/.kamal/secrets.example

# Local backup restore-drill scratch data (issue #028): dumps and
# temporary restore targets used while exercising docs/ops/restore.md
# never belong in the repository, same rationale as *.dump below.
/tmp/restore-drill/

# Manually downloaded border datasets (Cliopatria, historical-basemaps):
# the import mix tasks recommend keeping them here between runs, never
# committed (see lib/mix/tasks/amanogawa.import.*.ex).
/priv/data/

# Database dumps.
*.dump
*.sql.gz
